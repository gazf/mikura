{
  "tasks": {
    "dev": "deno run --watch --allow-net --allow-read --allow-write --allow-env --allow-sys=statfs --unstable-kv src/main.ts",
    "test": "deno test --allow-net --allow-read --allow-write --allow-env --allow-sys=statfs --unstable-kv tests/",
    "seed": "deno run --allow-read --allow-write --allow-env --unstable-kv src/kv/seed.ts",
    "gen-cert": "deno run --allow-read --allow-write --allow-run=openssl gen-dev-cert.ts"
  },
  "imports": {
    "hono": "jsr:@hono/hono@^4",
    "@hono/hono": "jsr:@hono/hono@^4",
    "@std/path": "jsr:@std/path@^1",
    "@std/assert": "jsr:@std/assert@^1"
  },
  "compilerOptions": {
    "strict": true
  }
}
